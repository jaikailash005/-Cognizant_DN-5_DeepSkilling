CREATE OR REPLACE TRIGGER LogTransaction
AFTER INSERT
ON Transactions
FOR EACH ROW
BEGIN

    INSERT INTO AuditLog
    (
        TransactionID,
        AccountID,
        Amount,
        TransactionDate,
        ActionType
    )
    VALUES
    (
        :NEW.TransactionID,
        :NEW.AccountID,
        :NEW.Amount,
        SYSDATE,
        'INSERT'
    );

END;
/

