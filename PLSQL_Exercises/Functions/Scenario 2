CREATE OR REPLACE FUNCTION CalculateMonthlyInstallment (
    p_loan_amount   NUMBER,
    p_interest_rate NUMBER,
    p_years         NUMBER
)
RETURN NUMBER
IS
    v_monthly_installment NUMBER;
BEGIN

    v_monthly_installment :=
        (p_loan_amount +
        (p_loan_amount *
         p_interest_rate / 100 *
         p_years))
        /
        (p_years * 12);

    RETURN v_monthly_installment;

END;
/